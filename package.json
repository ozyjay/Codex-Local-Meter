{
  "name": "codex-local-meter",
  "displayName": "Codex Local Meter",
  "description": "Local-only Codex usage estimates in the VS Code status bar from your local ~/.codex session files.",
  "version": "0.3.4",
  "publisher": "CrunchyCodes",
  "license": "MIT",
  "icon": "images/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "codex",
    "codex cli",
    "openai codex",
    "usage",
    "rate limit",
    "meter",
    "status bar",
    "local",
    "privacy"
  ],
  "galleryBanner": {
    "color": "#151521",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ozyjay/Codex-Local-Meter.git"
  },
  "bugs": {
    "url": "https://github.com/ozyjay/Codex-Local-Meter/issues"
  },
  "homepage": "https://github.com/ozyjay/Codex-Local-Meter#readme",
  "qna": false,
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "icons": {
      "codex-local-meter": {
        "description": "Codex Local Meter status icon",
        "default": {
          "fontPath": "./images/codex-local-meter.woff",
          "fontCharacter": "\\EA01"
        }
      }
    },
    "commands": [
      {
        "command": "codexLocalMeter.openStatus",
        "title": "Codex Local Meter: Open Status"
      },
      {
        "command": "codexLocalMeter.refreshNow",
        "title": "Codex Local Meter: Refresh Now"
      },
      {
        "command": "codexLocalMeter.selectCodexFolder",
        "title": "Codex Local Meter: Select Codex Folder"
      },
      {
        "command": "codexLocalMeter.openSettings",
        "title": "Codex Local Meter: Open Settings"
      },
      {
        "command": "codexLocalMeter.showDiagnostics",
        "title": "Codex Local Meter: Show Diagnostics"
      }
    ],
    "configuration": {
      "title": "Codex Local Meter",
      "properties": {
        "codexLocalMeter.codexPath": {
          "type": "string",
          "default": "",
          "description": "Override the Codex folder path. Leave empty to use ~/.codex."
        },
        "codexLocalMeter.refreshIntervalSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 30,
          "description": "How often to re-read Codex files (seconds). Minimum 30."
        },
        "codexLocalMeter.showFiveHourUsage": {
          "type": "boolean",
          "default": true,
          "description": "Show 5-hour estimated usage in the status bar."
        },
        "codexLocalMeter.showWeeklyUsage": {
          "type": "boolean",
          "default": true,
          "description": "Show 7-day estimated usage in the tooltip."
        },
        "codexLocalMeter.warningThresholdPercent": {
          "type": "number",
          "default": 70,
          "minimum": 0,
          "maximum": 100,
          "description": "Show yellow warning color at or above this percentage."
        },
        "codexLocalMeter.dangerThresholdPercent": {
          "type": "number",
          "default": 90,
          "minimum": 0,
          "maximum": 100,
          "description": "Show red danger color at or above this percentage."
        },
        "codexLocalMeter.compactMode": {
          "type": "boolean",
          "default": false,
          "description": "Shorten status bar text (e.g. '42%' instead of '42% 5h')."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "unit-test": "mocha out/test/suite/usageCalculator.test.js out/test/suite/codexReader.test.js out/test/suite/statusBarText.test.js out/test/suite/statusBarColors.test.js out/test/suite/iconAssets.test.js out/test/suite/refreshScheduler.test.js out/test/suite/runTests.test.js --timeout 10000 --ui tdd",
    "test": "node ./out/test/runTests.js",
    "lint": "eslint src --ext ts",
    "package:vsix": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/RebuildVsix.ps1",
    "package:patch": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/RebuildVsix.ps1 -VersionBump patch",
    "package:minor": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/RebuildVsix.ps1 -VersionBump minor",
    "package:major": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/RebuildVsix.ps1 -VersionBump major"
  },
  "devDependencies": {
    "@resvg/resvg-js-cli": "^2.6.2-beta.1",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vscode/test-electron": "^2.3.8",
    "@vscode/vsce": "^3.9.2",
    "eslint": "^8.56.0",
    "mocha": "^11.3.0",
    "svgtofont": "^6.5.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "mocha": {
      "serialize-javascript": "7.0.5"
    }
  }
}
